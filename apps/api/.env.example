# =========================
# Auth / JWT
# =========================
JWT_ACCESS_SECRET="change-me"
JWT_ACCESS_EXPIRES_IN="15m"

JWT_REFRESH_SECRET="change-me"
JWT_REFRESH_EXPIRES_IN="30d"

# =========================
# Database
# =========================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/career_navigator?schema=public"

# =========================
# Redis
# =========================
REDIS_URL="redis://localhost:6379"

# =========================
# OpenSearch
# =========================
OPENSEARCH_URL="http://localhost:9200"
OPENSEARCH_USERNAME="admin"
OPENSEARCH_PASSWORD="change-me"

# =========================
# Object storage (MinIO)
# =========================
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="change-me"
MINIO_SECRET_KEY="change-me"
MINIO_BUCKET="resumes"

# =========================
# Email (OTP verification)
# =========================
# When true, OTP is logged to server console and NOT emailed.
OTP_EMAIL_LOG_ONLY="false"
BREVO_API_KEY="change-me"
BREVO_SENDER_EMAIL="no-reply@example.com"

# =========================
# AI (Gemini)
# =========================
# Required for Gemini-based CV extraction in `cv-scan-worker` (DOCX + PDF -> structured JSON).
# If GEMINI_API_KEY is missing and CV_SCAN_ENABLED=true, CV scan processing will fail.
GEMINI_API_KEY="change-me"
# (Gemini model is currently hardcoded in code: gemini-2.5-flash)

# =========================
# AI (Ollama) (optional fallback)
# =========================
# Used only as a fallback by AiService when GEMINI_API_KEY is not set or Gemini is unavailable.
# For local Ollama: set OLLAMA_BASE_URL to your local instance (no API key needed).
# For Ollama Cloud: set both OLLAMA_BASE_URL and OLLAMA_API_KEY.
OLLAMA_BASE_URL="https://ollama.com/v1"
OLLAMA_API_KEY=""

# =========================
# Video calling (Agora)
# =========================
AGORA_APP_ID="change-me"
AGORA_APP_CERTIFICATE="change-me"

# =========================
# CORS
# =========================
CORS_ALLOWED_ORIGINS="http://localhost:3000"
